# Copy this file to .env.local and fill in real values before running Docker.
#
# PowerShell:
#   Copy-Item env.example .env.local
#   docker compose --env-file .env.local up -d --build
#
# Or with a pulled image:
#   docker run --rm -p 127.0.0.1:8787:8787 --env-file .env.local ghcr.io/YOUR_ORG/claude-codex-proxy:latest

# Required: OpenAI-compatible Responses backend.
CLAUDE_CODE_PROXY_BACKEND_BASE_URL=
CLAUDE_CODE_PROXY_BACKEND_API_KEY=

# Recommended: pin the real backend model so Claude Code display model names
# such as claude-sonnet-* / claude-opus-* do not leak through to the backend.
CLAUDE_CODE_PROXY_BACKEND_MODEL=gpt-5.4

# Required for Docker because the image listens on 0.0.0.0:8787 inside the container.
# Claude Code should use the same value as ANTHROPIC_AUTH_TOKEN.
CLAUDE_CODE_PROXY_CLIENT_API_KEY=replace-with-a-local-shared-key

# Optional.
# CLAUDE_CODE_PROXY_BACKEND_PATH=/v1/responses
# CLAUDE_CODE_PROXY_REQUEST_TIMEOUT=120s
# CLAUDE_CODE_PROXY_ANTHROPIC_MODEL_ALIAS=claude-sonnet-4-5
# CLAUDE_CODE_PROXY_BACKEND_REASONING_EFFORT=medium
# CLAUDE_CODE_PROXY_ANTHROPIC_API_KEY=
# CLAUDE_CODE_PROXY_ANTHROPIC_API_BASE_URL=https://api.anthropic.com
# CLAUDE_CODE_PROXY_ENABLE_BACKEND_METADATA=false
# CLAUDE_CODE_PROXY_FORWARD_USER_METADATA=false
# CLAUDE_CODE_PROXY_USER_METADATA_ALLOWLIST=
# CLAUDE_CODE_PROXY_DISABLE_CONTINUITY_METADATA=false
# CLAUDE_CODE_PROXY_DISABLE_PROMPT_CACHE_KEY=false
# CLAUDE_CODE_PROXY_ANONYMOUS_MODE=false
# CLAUDE_CODE_PROXY_ENABLE_MODEL_CAPABILITY_INIT=false
# CLAUDE_CODE_PROXY_ENABLE_PHASE_COMMENTARY=false
# CLAUDE_CODE_PROXY_DISABLE_BACKEND_STREAMING=false
# CLAUDE_CODE_PROXY_DEBUG=false
